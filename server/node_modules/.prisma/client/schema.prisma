generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id        String        @id @default(uuid())
  name      String
  isPrivate Boolean       @default(false)
  hostId    String
  purse     Int           @default(120)
  squadSize Int           @default(25)
  bidTimer  Int           @default(10)
  createdAt DateTime      @default(now())
  squads    SquadMember[]
}

model Player {
  id          String        @id @default(uuid())
  name        String
  role        String
  country     String? // Optional field
  basePrice   Float
  category    String
  overseas    Boolean
  nationality String
  batting     Int
  bowling     Int
  fielding    Int
  experience  Int
  captaincy   Int
  squads      SquadMember[]
}

// This connects the Player to the Room (The Squad)
model SquadMember {
  id String @id @default(uuid())

  // Link to Player
  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  // Link to Room (Auction)
  roomId String
  room   Room   @relation(fields: [roomId], references: [id])

  // You can add fields like 'boughtPrice' or 'ownerName' here later
  createdAt DateTime @default(now())
}

// Kept this in case you use it for historical records
model Auction {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}
