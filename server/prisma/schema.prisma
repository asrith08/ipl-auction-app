generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id          String   @id @default(uuid())
  name        String
  isPrivate   Boolean  @default(false)
  hostId      String
  purse       Int      @default(120)
  squadSize   Int      @default(25)
  bidTimer    Int      @default(10)
  createdAt   DateTime @default(now())
  squads      SquadMember[]
}

model Player {
  id          String   @id @default(uuid())
  name        String
  role        String
  country     String
  basePrice   Float
  category    String
  overseas    Boolean
  batting     Int
  bowling     Int
  fielding    Int
  experience  Int
  captaincy   Int
  squads      SquadMember[]
}

model Player {
  id        String   @id @default(uuid())
  name      String
  role      String
  country   String?  // The "?" makes it optional
  // ... rest of the fields
}